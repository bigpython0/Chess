{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SFML Debug (Mac)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/chess_game",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "DYLD_LIBRARY_PATH",
          "value": "/opt/homebrew/opt/sfml/lib"
        }
      ],
      "externalConsole": false,
      "MIMode": "lldb"
    }
  ]
}